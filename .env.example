############################################
# Mensagelo (HTTP mailer)
############################################
TZ=America/Argentina/Buenos_Aires
MENSAGELO_API_KEY=COMPLETAR_API_KEY
MENSAGELO_SERVICE_HOST=0.0.0.0
MENSAGELO_SERVICE_PORT=8081
MENSAGELO_DATABASE_DIR=/app/data
MENSAGELO_DATABASE_NAME=messaging.db
MENSAGELO_QUEUE_MAXSIZE=1000
MENSAGELO_BASE_URL=http://mensagelo:8081

# SMTP upstream (used by mensagelo)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=usuario@example.com
SMTP_PASSWORD=COMPLETAR_SMTP_PASSWORD
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

############################################
# MQTT broker (shared by all services)
############################################
MQTT_BROKER_HOST=broker.example.com
MQTT_BROKER_PORT=8883
MQTT_BROKER_USERNAME=COMPLETAR_BROKER_USERNAME
MQTT_BROKER_PASSWORD=COMPLETAR_BROKER_PASSWORD
MQTT_BROKER_USE_TLS=true
MQTT_TLS_INSECURE=false
MQTT_BROKER_KEEPALIVE=60
MQTT_CONNECT_TIMEOUT=15
MQTT_RECONNECT_DELAY_MIN=5
MQTT_RECONNECT_DELAY_MAX=60
MQTT_TOPIC_MODEM_CONEXION=exemys/estado/conexion_modem
MQTT_TOPIC_GRADO=exemys/estado/grado
MQTT_TOPIC_GRDS=exemys/estado/grds
MQTT_TOPIC_EMAIL_ESTADO=exemys/estado/email
MQTT_TOPIC_EMAIL_EVENT=exemys/eventos/email
MQTT_TOPIC_PROXMOX_ESTADO=exemys/estado/proxmox
MQTT_PUBLISH_QOS_STATE=1
MQTT_PUBLISH_RETAIN_STATE=true
MQTT_PUBLISH_QOS_EVENT=1
MQTT_PUBLISH_RETAIN_EVENT=false
MQTT_ROUTER_CLIENT_ID=router-telef-service

############################################
# modbus-mw-service
############################################
MODBUS_MW_MB_HOST=modbus-gateway.example.internal
MODBUS_MW_MB_PORT=502
MODBUS_MW_MB_ID=22
MODBUS_MW_MB_COUNT=16
MODBUS_MW_MB_INTERVAL_SECONDS=60
MODBUS_MW_DATA_DIR=/app/data
MODBUS_MW_DATABASE_NAME=grdconectados.db
MODBUS_MW_API_BASE=http://modbus-mw-service:8084
MODBUS_MW_HTTP_TIMEOUT=5
MODBUS_HTTP_POLL_SECONDS=20
MODBUS_MQTT_REFRESH_FACTOR=5
GE_EMAR_GRD_ID=14
GE_EMAR_REGISTER_OFFSET=9
GE_EMAR_BIT_INDEX=0
GE_EMAR_TOPIC=exemys/estado/ge_emar

############################################
# panelexemys (Dash)
############################################
PANELEXEMYS_HOST=0.0.0.0
PANELEXEMYS_PORT=8052
PANELEXEMYS_DATA_DIR=/app/data
PUBLIC_BASE_URL=https://monitor.example.com
DASH_REFRESH_SECONDS=10000
GLOBAL_THRESHOLD_ROJO=40
GLOBAL_THRESHOLD_AMARILLO=85
ALARM_CHECK_INTERVAL_SECONDS=20
ALARM_MIN_SUSTAINED_DURATION_MINUTES=30
ALARM_EMAIL_RECIPIENT=operaciones@example.com,alertas@example.com
ALARM_EMAIL_SUBJECT_PREFIX=[monitor]
MENSAGELO_TIMEOUT_SECONDS=5
MENSAGELO_MAX_RETRIES=5
MENSAGELO_BACKOFF_INITIAL=0.5
MENSAGELO_BACKOFF_MAX=8.0
MQTT_SERVICE_STATUS_TOPIC=panelexemys/status
MQTT_SERVICE_STATUS_QOS=1
MQTT_SERVICE_STATUS_RETAIN=true
MQTT_WILL_PAYLOAD={"status":"offline","reason":"lwt"}
CHARITO_API_BASE=http://charito-service:8082
CHARITO_STALE_THRESHOLD_SECONDS=180
PVE_API_BASE=http://pve-service:8083
ROUTER_SERVICE_BASE_URL=http://router-telef-service:8086
ROUTER_CLIENT_TIMEOUT_SECONDS=5
MODEM_EXTERNAL_CHECK_URL=https://port-check.example.com/
MODEM_ADMIN_URL=http://modem.example.internal/
EMAIL_HEALTH_SMTP_HOST=smtp.example.com
EMAIL_HEALTH_PING_LOCAL_HOST=edge-gateway.example.internal
EMAIL_HEALTH_PING_REMOTE_HOST=smtp.example.com

############################################
# router-telef-service
############################################
TARGET_IP=203.0.113.10
TARGET_PORT=40000
PROBE_INTERVAL_SECONDS=300
CHECK_HOST_BASE_URL=https://check-host.net
CHECK_HOST_MAX_NODES=3
CHECK_HOST_SUCCESS_LATENCY_SECONDS=3.0
CHECK_HOST_RESULT_TIMEOUT_SECONDS=20.0
CHECK_HOST_POLL_INTERVAL_SECONDS=5.0
CHECK_HOST_REQUEST_TIMEOUT_SECONDS=10.0

############################################
# charito-service
############################################
CHARITO_DATA_DIR=/app/data
CHARITO_STATE_FILE=/app/data/charito-state.json
CHARITO_TARGETS_JSON={"pollIntervalSeconds":20,"httpTimeoutSeconds":4,"instances":[{"alias":"host-01","baseUrl":"http://host-01.example.internal:8080"},{"alias":"host-02","baseUrl":"http://host-02.example.internal:8080"}]}
CHARITO_POLL_INTERVAL_SECONDS=20
CHARITO_HTTP_TIMEOUT_SECONDS=4
CHARITO_MQTT_TOPIC=charito/whitelist/instances

############################################
# pve-service
############################################
PVE_DATA_DIR=/app/data
PVE_BASE_URL=https://proxmox.example.internal:8006/api2/json
PVE_API_TOKEN=USUARIO@realm!token_id=COMPLETAR_TOKEN_SECRET
PVE_NODE_NAME=pve-node
PVE_VHOST_IDS=102,107,110
PVE_HTTP_TIMEOUT_SECONDS=15
PVE_VERIFY_SSL=false
PVE_POLL_INTERVAL_SECONDS=120
PVE_HISTORY_HOURS=72
PVE_MQTT_PUBLISH_FACTOR=5
PVE_STATE_FILE=pve_state.json
PVE_HISTORY_FILE=proxmox_history.json

############################################
# scada-citec-service
############################################
CITEC_ADAPTER_QUERY_INTERVAL_SECONDS=120
CITEC_REFRESH_ON_START=true
CITEC_TAG_REFRESH_INTERVAL_SECONDS=300
SCADA_DAEMON_BASE_URL=http://scada-daemon.example.internal:8080
SCADA_CITEC_SERVICE_PORT=8094
SCADA_STATIC_CACHE_SECONDS=60

############################################
# login-service
############################################
LOGIN_PROTECTED_USER=admin
LOGIN_PROTECTED_PASS=COMPLETAR_PASSWORD_PROTEGIDO
LOGIN_CHATCHETO_ATENDEDOR_HOST=host.docker.internal
LOGIN_CHATCHETO_ATENDEDOR_PORT=5173
LOGIN_CHATCHETO_API_HOST=host.docker.internal
LOGIN_CHATCHETO_API_PORT=4000
LOGIN_CHATCHETO_GEO_HOST=host.docker.internal
LOGIN_CHATCHETO_GEO_PORT=4500
LOGIN_CHATCHETO_DASHBOARD_HOST=host.docker.internal
LOGIN_CHATCHETO_DASHBOARD_PORT=4200
